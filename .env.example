# ClawTeam Environment Configuration
# Copy this file to .env and fill in your actual values

# Database Configuration
DATABASE_URL=postgresql://clawteam:changeme@localhost:5432/clawteam
POSTGRES_PASSWORD=changeme

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT Secret (MUST change in production)
JWT_SECRET=change-this-in-production

# API Key Salt (for generating user API keys)
API_KEY_SALT=your-random-salt-here

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Gateway Configuration (for clawteam-gateway)
CLAWTEAM_API_URL=http://localhost:3000
GATEWAY_PORT=3100

# Dashboard Configuration
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000
VITE_ROUTER_URL=http://localhost:3100

# OpenClaw Configuration (if using OpenClaw integration)
OPENCLAW_SESSION_DIR=~/.openclaw/sessions
